import tkinter as tk
from tkinter import messagebox


class Vendedor:

    def __init__(self, nombre, apellido, edad):
        self.nombre = nombre
        self.apellido = apellido
        self.edad = edad

    def verificar_edad(self):

        if self.edad < 0 or self.edad > 120:
            raise ValueError(
                "La edad no puede ser negativa ni mayor a 120"
            )

        if self.edad <= 18:
            raise ValueError(
                "El vendedor debe ser mayor de 18 años"
            )

    def imprimir(self):
        return (
            f"Nombre del vendedor: {self.nombre}\n"
            f"Apellido del vendedor: {self.apellido}\n"
            f"Edad del vendedor: {self.edad}"
        )


def calcular():

    try:

        nombre = txt_nombre.get().strip()
        apellido = txt_apellido.get().strip()
        edad = int(txt_edad.get())

        vendedor = Vendedor(nombre, apellido, edad)

        vendedor.verificar_edad()

        messagebox.showinfo(
            "Nombre del vendedor",
            vendedor.nombre
        )

        messagebox.showinfo(
            "Apellido del vendedor",
            vendedor.apellido
        )

        messagebox.showinfo(
            "Edad del vendedor",
            vendedor.edad
        )

        print(vendedor.imprimir())

    except ValueError as e:
        messagebox.showerror(
            "Error al Validación d'Edad",
            str(e)
        )


def limpiar():

    txt_nombre.delete(0, tk.END)
    txt_apellido.delete(0, tk.END)
    txt_edad.delete(0, tk.END)


ventana = tk.Tk()
ventana.title("Vendedor")
ventana.geometry("700x300")
ventana.resizable(False, False)


lbl_nombre = tk.Label(
    ventana,
    text="Nombre del Vendedor"
)
lbl_nombre.place(x=60, y=50)

txt_nombre = tk.Entry(
    ventana,
    width=35
)
txt_nombre.place(x=260, y=50)


lbl_apellido = tk.Label(
    ventana,
    text="Apellido del Vendedor"
)
lbl_apellido.place(x=60, y=100)

txt_apellido = tk.Entry(
    ventana,
    width=35
)
txt_apellido.place(x=260, y=100)


lbl_edad = tk.Label(
    ventana,
    text="Edad del Vendedor"
)
lbl_edad.place(x=60, y=150)

txt_edad = tk.Entry(
    ventana,
    width=35
)
txt_edad.place(x=260, y=150)


btn_calcular = tk.Button(
    ventana,
    text="Calcular",
    width=12,
    command=calcular
)
btn_calcular.place(x=220, y=220)


btn_limpiar = tk.Button(
    ventana,
    text="Limpiar",
    width=12,
    command=limpiar
)
btn_limpiar.place(x=380, y=220)


ventana.mainloop()
