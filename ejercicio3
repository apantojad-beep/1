import tkinter as tk
from tkinter import messagebox
import math


class CalculosNumericos:

    @staticmethod
    def calcular_logaritmo_neperiano(valor):
        if valor < 0:
            raise ArithmeticError(
                "El valor debe ser un número positivo para calcular el logaritmo"
            )
        return round(math.log(valor), 4)

    @staticmethod
    def calcular_raiz_cuadrada(valor):
        if valor < 0:
            raise ArithmeticError(
                "El valor debe ser un número positivo para calcular la raíz cuadrada"
            )
        return round(math.sqrt(valor), 4)


class Ventana:
    def __init__(self, root):
        self.root = root
        self.root.title("Cálculos Numéricos")
        self.root.geometry("420x220")
        self.root.resizable(False, False)

        # Etiquetas
        tk.Label(root, text="Valor numérico").place(x=50, y=40)
        tk.Label(root, text="Logaritmo Neperiano").place(x=50, y=80)
        tk.Label(root, text="Raíz Cuadrada").place(x=50, y=120)

        # Cajas de texto
        self.txt_valor = tk.Entry(root, width=20)
        self.txt_valor.place(x=220, y=40)

        self.txt_log = tk.Entry(root, width=20)
        self.txt_log.place(x=220, y=80)

        self.txt_raiz = tk.Entry(root, width=20)
        self.txt_raiz.place(x=220, y=120)

        # Botones
        btn_calcular = tk.Button(
            root,
            text="Calcular",
            bg="#5B9BD5",
            fg="white",
            width=10,
            command=self.calcular
        )
        btn_calcular.place(x=80, y=170)

        btn_limpiar = tk.Button(
            root,
            text="Limpiar",
            bg="#5B9BD5",
            fg="white",
            width=10,
            command=self.limpiar
        )
        btn_limpiar.place(x=240, y=170)

    def calcular(self):
        try:
            valor = float(self.txt_valor.get())

            try:
                resultado_log = CalculosNumericos.calcular_logaritmo_neperiano(valor)
                self.txt_log.delete(0, tk.END)
                self.txt_log.insert(0, resultado_log)
            except ArithmeticError as e:
                self.txt_log.delete(0, tk.END)
                messagebox.showerror("Error", str(e))

            try:
                resultado_raiz = CalculosNumericos.calcular_raiz_cuadrada(valor)
                self.txt_raiz.delete(0, tk.END)
                self.txt_raiz.insert(0, resultado_raiz)
            except ArithmeticError as e:
                self.txt_raiz.delete(0, tk.END)
                messagebox.showerror("Error", str(e))

        except ValueError:
            messagebox.showerror(
                "Error",
                "El valor debe ser numérico"
            )

    def limpiar(self):
        self.txt_valor.delete(0, tk.END)
        self.txt_log.delete(0, tk.END)
        self.txt_raiz.delete(0, tk.END)


if __name__ == "__main__":
    root = tk.Tk()
    app = Ventana(root)
    root.mainloop()
